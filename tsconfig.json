{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["esnext", "dom"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}